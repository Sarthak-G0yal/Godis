# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work.lock

# IDE/editor-specific files and directories, such as for VS Code, macOS, etc.
# These can also be added to a global gitignore file (see GitHub Docs for more info)
.idea/
.vscode/
.DS_Store
Thumbs.db
*.aof